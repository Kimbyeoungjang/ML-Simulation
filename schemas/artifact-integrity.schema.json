{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TileForge artifact integrity manifest",
  "type": "object",
  "required": ["schemaVersion", "jobId", "generatedAt", "artifacts"],
  "properties": {
    "schemaVersion": { "const": "tileforge.integrity.v1" },
    "jobId": { "type": "string" },
    "generatedAt": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path", "sizeBytes", "sha256"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "sizeBytes": { "type": "number", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "verifiedAt": { "type": "string" },
          "schemaVersion": { "type": "string" }
        }
      }
    }
  }
}
