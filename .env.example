# TileForge external tool commands
# Copy to .env or run `npm run setup:env` to auto-detect local paths.
TILEFORGE_SCALE_SIM_CMD="py -3 -m scalesim.scale"
TILEFORGE_IREE_COMPILE_CMD="py -3 -m iree.compiler.tools.scripts.iree_compile"

# Queue/runtime defaults
TILEFORGE_MAX_PARALLEL_JOBS="6"
TILEFORGE_MAX_PARALLEL_JOBS_CAP="8"
TILEFORGE_MAX_QUEUED_JOBS="10000"
TILEFORGE_JOB_TIMEOUT_MS="1800000"
TILEFORGE_JOB_MAX_ATTEMPTS="1"
TILEFORGE_MAX_JOB_LOG_LINES="300"
TILEFORGE_TRAIN_HEAP_MB="12288"
TILEFORGE_RUNNING_RECOVERY_INTERVAL_MS="30000"
TILEFORGE_STALE_RUNNING_GRACE_MS="30000"

# Storage/cache defaults
TILEFORGE_SQLITE_PRIMARY="1"
TILEFORGE_DISABLE_SQLITE="0"
TILEFORGE_DISABLE_CACHE="0"
TILEFORGE_KEEP_EXTERNAL_RAW="0"
TILEFORGE_EXTERNAL_KEEP_REPORT_MAX_BYTES="26214400"
TILEFORGE_MAX_EXTERNAL_OUTPUT_BYTES="200000"
TILEFORGE_MAX_ARTIFACTS_MB="256"
TILEFORGE_MAX_BUNDLE_MB="512"
TILEFORGE_EXTERNAL_STATUS_CACHE_MS="10000"
TILEFORGE_STATUS_COUNTS_CACHE_MS="5000"
TILEFORGE_STATUS_SIZE_CACHE_MS="60000"
# Recursive storage scanning is expensive with thousands of artifacts. Enable only when idle and you need exact storage size.
TILEFORGE_STATUS_SCAN_STORAGE="0"

# UI/estimator guardrails
TILEFORGE_MAX_CANDIDATES="20000"
TILEFORGE_HEATMAP_MAX_POINTS="5000"
TILEFORGE_MAX_PREDICTION_ARTIFACT_ROWS="20000"

# Large-queue UI safety: keep Jobs dashboard lightweight while full-pipeline jobs are running.
TILEFORGE_JOBS_DASHBOARD_ARTIFACTS="0"
TILEFORGE_SQLITE_BUSY_TIMEOUT_MS="250"
TILEFORGE_SQLITE_FULL_JSON_WRITE_INTERVAL_MS="15000"
TILEFORGE_JOBS_API_CACHE_MS="2000"
TILEFORGE_JOBS_FAST_FALLBACK="1"
